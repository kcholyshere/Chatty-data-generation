# Copy to .env and fill in. The project standard is Vertex AI (no plain API keys).

# --- Vertex AI (recommended; auth via `gcloud auth application-default login`) ---
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# `global` serves the newest Gemini models; some are not in regional endpoints like us-central1.
GOOGLE_CLOUD_LOCATION=global

# --- Gemini API key (local dev only; NOT spec-conformant, ignored by the Docker setup) ---
# GOOGLE_GENAI_USE_VERTEXAI=false
# GEMINI_API_KEY=your-key-here

# Model (Gemini 2.0 Flash or newer)
GEMINI_MODEL=gemini-3.5-flash

# --- Langfuse (optional observability) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- PostgreSQL (defaults match docker-compose; in the app container set POSTGRES_HOST=db) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chatty
POSTGRES_USER=chatty
POSTGRES_PASSWORD=chatty
