# Copy to .env and fill in. Choose ONE auth method for Gemini.

# --- Option A: Vertex AI (GCP project; auth via `gcloud auth application-default login`) ---
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# `global` serves the newest Gemini models; some are not in regional endpoints like us-central1.
GOOGLE_CLOUD_LOCATION=global

# --- Option B: Gemini API key (set USE_VERTEXAI=false) ---
# GOOGLE_GENAI_USE_VERTEXAI=false
# GEMINI_API_KEY=your-api-key

# Model (Gemini 2.0 Flash or newer)
GEMINI_MODEL=gemini-3.5-flash

# --- Langfuse (optional observability) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
